# Sao chép file này thành .env rồi điền giá trị (setup.ps1 / setup.sh tự tạo .env nếu chưa có)
#
# Dataset Kaggle (bắt buộc khi máy chưa có thư mục dataset/)
# Ví dụ: KAGGLE_DATASET_SLUG=username/student-behavior-har
KAGGLE_DATASET_SLUG=

# Token API Kaggle (https://www.kaggle.com/settings → Generate New Token)
# Hoặc chạy: kagglehub login
KAGGLE_API_TOKEN=
